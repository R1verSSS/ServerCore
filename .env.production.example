# ============================================================================
# SERVERCORE — КОНФИГУРАЦИЯ ОКРУЖЕНИЯ
# ============================================================================
# Скопируй этот файл в .env и заполни значения.
# Никогда не публикуй .env и не добавляй его в GitHub.
# Значения true/false указываются без кавычек.
# Пустые ID означают: использовать настройку из базы или найти объект по имени.
# ============================================================================

# ----------------------------------------------------------------------------
# 1. DISCORD — ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ
# ----------------------------------------------------------------------------
# Bot Token: Discord Developer Portal -> Bot -> Reset Token / Copy.
DISCORD_TOKEN=

# Application ID / Client ID: Discord Developer Portal -> General Information.
CLIENT_ID=

# ID основного Discord-сервера.
GUILD_ID=


# ----------------------------------------------------------------------------
# 2. РЕЖИМ ЗАПУСКА
# ----------------------------------------------------------------------------
NODE_ENV=production

# В production оба параметра должны быть false.
TEST_MODE=false
DEMO_MODE=false


# ----------------------------------------------------------------------------
# 3. ВЕБ-ПАНЕЛЬ АДМИНИСТРАТОРА И ПОЛЬЗОВАТЕЛЕЙ
# ----------------------------------------------------------------------------
WEB_PANEL_ENABLED=true

# Внутренний порт приложения. На некоторых хостингах PORT задаётся автоматически.
WEB_PORT=3000
PORT=

# Надёжный пароль администратора веб-панели.
WEB_PASSWORD=

# Случайная строка длиной не менее 24 символов для сессий.
WEB_SESSION_TOKEN=

# Публичная ссылка на страницу входа.
WEB_PANEL_URL=https://example.com/login

# Резервное имя той же публичной ссылки для совместимости.
PUBLIC_WEB_PANEL_URL=

# Защита от перебора пароля.
WEB_LOGIN_LIMIT=5
WEB_LOGIN_LOCK_MINUTES=30

# Срок действия пользовательской веб-сессии и одноразового кода.
USER_WEB_SESSION_HOURS=24
USER_WEB_CODE_MINUTES=10


# ----------------------------------------------------------------------------
# 4. БАЗА ДАННЫХ И ХРАНИЛИЩЕ
# ----------------------------------------------------------------------------
# sqlite — рекомендуется для VPS/Node.js 20+.
# json   — запасной вариант для хостинга без поддержки better-sqlite3.
DB_DRIVER=sqlite

# Путь внутри контейнера/VPS. Для локального запуска можно: ./data/database.sqlite
SQLITE_PATH=/app/data/database.sqlite


# ----------------------------------------------------------------------------
# 5. DISCORD-КАНАЛЫ: ЗАЯВКИ И ЖАЛОБЫ
# ----------------------------------------------------------------------------
APPLICATIONS_CHANNEL_ID=
COMPLAINTS_CHANNEL_ID=
COMPLAINTS_CHANNEL_NAME=🚨・жалобы


# ----------------------------------------------------------------------------
# 6. ТИКЕТЫ
# ----------------------------------------------------------------------------
# Категория для открытых приватных тикетов.
TICKET_ACTIVE_CATEGORY_NAME=🎫 АКТИВНЫЕ ТИКЕТЫ
TICKET_ACTIVE_CATEGORY_ID=

# Канал или Forum-канал, куда архивируются закрытые тикеты.
TICKET_ARCHIVE_CHANNEL_NAME=📁・тикеты
TICKET_ARCHIVE_CHANNEL_ID=


# ----------------------------------------------------------------------------
# 7. ЭКОНОМИКА, DAILY И ONBOARDING
# ----------------------------------------------------------------------------
DAILY_COOLDOWN_HOURS=24
DAILY_COINS=100
DAILY_XP=25
ONBOARDING_REWARD_COINS=100

# Товар дня в магазине.
SHOP_DAILY_DEAL_ENABLED=true
SHOP_DAILY_DEAL_DISCOUNT=20


# ----------------------------------------------------------------------------
# 8. МУЗЫКАЛЬНЫЙ МОДУЛЬ
# ----------------------------------------------------------------------------
# На Bothost может потребоваться false из-за ограничений Discord Voice/UDP.
MUSIC_ENABLED=false

# Диагностические сообщения музыкального модуля.
MUSIC_DEBUG=false

# Принудительное использование IPv4 при сетевых проблемах.
MUSIC_FORCE_IPV4=true

# Максимум треков, добавляемых из плейлиста.
MUSIC_MAX_PLAYLIST_ITEMS=15

# Время ожидания подключения к voice-каналу, мс.
MUSIC_CONNECT_TIMEOUT=45000

# Показывать предупреждение о возможных ограничениях хостинга.
MUSIC_HOSTING_WARNING=true


# ----------------------------------------------------------------------------
# 9. DISCORD API, СЕТЬ И ПОВТОРНЫЕ ПОДКЛЮЧЕНИЯ
# ----------------------------------------------------------------------------
DISCORD_REST_TIMEOUT=60000
DISCORD_LOGIN_MAX_RETRIES=10
NETWORK_CHECK_TIMEOUT=8000

# Отключи предупреждение только после включения Message Content Intent.
MESSAGE_CONTENT_INTENT_WARNING=true


# ----------------------------------------------------------------------------
# 10. РЕЗЕРВНЫЕ КОПИИ И ОЧИСТКА ФАЙЛОВ
# ----------------------------------------------------------------------------
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_HOURS=24
AUTO_BACKUP_KEEP=14

# Срок хранения экспортов и логов в днях.
EXPORTS_KEEP_DAYS=14
LOGS_KEEP_DAYS=14


# ----------------------------------------------------------------------------
# 11. ЗАЩИЩЁННЫЕ КАНАЛЫ
# ----------------------------------------------------------------------------
# Дополнительные текстовые каналы, которые setup/cleanup не должен удалять.
# Несколько точных названий разделяются запятыми.
# Пример: правила,объявления,команды-бота
PROTECTED_TEXT_CHANNELS=
