# Discord bot
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Web panel
WEB_PANEL_ENABLED=true
WEB_PORT=3000
WEB_PASSWORD=
WEB_SESSION_TOKEN=

# Database
# For BotHost / Node.js 20 use json. If you deploy on Node.js 22+ and want node:sqlite, use sqlite.
DB_DRIVER=json
SQLITE_PATH=./data/database.sqlite

# Production mode
NODE_ENV=production
TEST_MODE=false
DEMO_MODE=false

# Discord REST/network
DISCORD_REST_TIMEOUT=60000
DISCORD_LOGIN_MAX_RETRIES=10

# Web panel security
WEB_LOGIN_LIMIT=5
WEB_LOGIN_LOCK_MINUTES=30

# Channel cleanup
# Comma-separated additional channel names where user messages should be auto-deleted.
PROTECTED_TEXT_CHANNELS=

# Music
MUSIC_MAX_PLAYLIST_ITEMS=15
MUSIC_CONNECT_TIMEOUT=15000
