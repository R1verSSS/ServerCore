# Discord bot
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Web panel
WEB_PANEL_ENABLED=true
WEB_PORT=3000
WEB_PASSWORD=
WEB_SESSION_TOKEN=
WEB_PANEL_URL=https://bot-1780694887-7211-r1vers.bothost.tech/login
WEB_LOGIN_LIMIT=5
WEB_LOGIN_LOCK_MINUTES=30

# Database
# Bothost: json. VPS/Node 22+: sqlite.
DB_DRIVER=sqlite
SQLITE_PATH=./data/database.sqlite

# Channel IDs
APPLICATIONS_CHANNEL_ID=1512791242000564229

# Production mode
NODE_ENV=production
TEST_MODE=false
DEMO_MODE=false

# Discord network/retry settings
DISCORD_REST_TIMEOUT=60000
DISCORD_LOGIN_MAX_RETRIES=10
NETWORK_CHECK_TIMEOUT=8000

# Backups
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_HOURS=24
AUTO_BACKUP_KEEP=14

# Modules
# Set false on Bothost if Discord Voice/UDP is unavailable.
MUSIC_ENABLED=false
MUSIC_MAX_PLAYLIST_ITEMS=15
MUSIC_CONNECT_TIMEOUT=30000
MUSIC_HOSTING_WARNING=true

# Protected channel cleanup
# Extra channels split by comma, names exactly as in Discord.
PROTECTED_TEXT_CHANNELS=

# Server Management UX Upgrade
SHOP_DAILY_DEAL_ENABLED=true
SHOP_DAILY_DEAL_DISCOUNT=20

# Discord channel IDs
APPLICATIONS_CHANNEL_ID=1512791242000564229

# Ticket flow
# Active tickets are private text channels under this category, not in moderation.
TICKET_ACTIVE_CATEGORY_NAME=🎫 ПОДДЕРЖКА
TICKET_ACTIVE_CATEGORY_ID=
# Closed tickets are archived here. Can be a text channel or Forum channel.
TICKET_ARCHIVE_CHANNEL_NAME=📁・тикеты
TICKET_ARCHIVE_CHANNEL_ID=
